<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 800 400">
  <defs>
    <linearGradient id="bg" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#4CAF50"/>
      <stop offset="100%" style="stop-color:#8BC34A"/>
    </linearGradient>
  </defs>
  <rect fill="url(#bg)" width="800" height="400"/>
  <text x="400" y="180" font-size="60" fill="white" text-anchor="middle" font-family="Arial, sans-serif" font-weight="bold">🌾 Sunny农产品</text>
  <text x="400" y="260" font-size="32" fill="rgba(255,255,255,0.9)" text-anchor="middle" font-family="Arial, sans-serif">大山里的好货 新鲜直达</text>
</svg>